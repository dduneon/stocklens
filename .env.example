# KRX 로그인 정보 (data.krx.co.kr 계정)
KRX_LOGIN_ID=your_krx_id_here
KRX_LOGIN_PW=your_krx_password_here

# Flask 설정
FLASK_DEBUG=false
FLASK_PORT=5001
SECRET_KEY=change-this-to-a-random-secret-key

# MariaDB — service-net 내 컨테이너 호스트명 사용
DATABASE_URL=mysql+pymysql://stocklens:your_password@mariadb:3306/stocklens

# DART 전자공시 API 키 (재무제표 수집, https://opendart.fss.or.kr/)
DART_API_KEY=your_dart_api_key_here
